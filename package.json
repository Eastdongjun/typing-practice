{
  "name": "typing-practice",
  "version": "1.0.0",
  "description": "打字练习 - 指法训练工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "bash scripts/check.sh",
    "check:req": "python3 scripts/check_requirements.py",
    "release:check": "npm run check && npm run check:req",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "publish:req": "bash scripts/publish_requirements.sh",
    "build:mac": "electron-builder --mac --arm64 --x64",
    "build:win": "electron-builder --win --x64",
    "build:all": "npm run build:mac && npm run build:win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.typing.practice",
    "productName": "打字练习",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "manifest.json",
      "icon-512.png",
      "icon-192.png"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon-512.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "打字练习"
    }
  },
  "allowScripts": {
    "electron@35.7.5": true
  }
}